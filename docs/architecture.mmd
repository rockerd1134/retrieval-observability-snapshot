flowchart LR
  source["Source descriptors\nGit refs or local paths"] --> import["Import\nmaterialize source snapshot\nselect files\nassign doc IDs"]
  import --> import_manifest["Import manifest\nsource descriptor hash\nselected and ignored files\nsnapshot identity hash"]
  import_manifest --> transform["Transform\nprepare dataset\noptional graph\noptional support"]
